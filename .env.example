# Telegram Client API credentials for Telethon / MTProto.
# Create these at https://my.telegram.org/apps.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local-only storage paths.
RELCHAT_DATA_DIR=./data
RELCHAT_DB_PATH=./data/relchat.sqlite3
RELCHAT_SESSION_PATH=./data/telegram.session

# Telegram Bot interface. The bot is only a user interface; Telethon / MTProto
# still reads selected Telegram chats through the local user session above.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty only when the bot is not being run; startup refuses an empty list.
RELCHAT_ALLOWED_USER_IDS=

# Optional OpenAI Responses API integration.
# Local deterministic analysis works when this remains disabled.
OPENAI_API_KEY=
RELCHAT_AI_ENABLED=false
RELCHAT_AI_MODEL=
RELCHAT_AI_MAX_MESSAGES=300
RELCHAT_AI_MAX_CHARS=30000
RELCHAT_AI_TIMEOUT_SECONDS=90
